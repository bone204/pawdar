datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 1. Quản lý Người dùng (Users) - Bản Nâng Cấp Hỗ Trợ Email Verification & Security
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  phoneNumber  String?  @map("phone_number")
  avatarUrl    String?  @map("avatar_url")
  role         String   @default("user") // user, admin, moderator
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // === PHÂN HỆ AUTH & BẢO MẬT NÂNG CẤP ===
  isEmailVerified     Boolean   @default(false) @map("is_email_verified")
  
  // Phục vụ luồng Kích hoạt tài khoản / Xác thực Email bằng Token hoặc OTP
  verificationToken   String?   @map("verification_token")
  verificationExpires DateTime? @map("verification_expires")

  // Phục vụ luồng Quên mật khẩu (Reset Password)
  resetPasswordToken   String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")

  // Trạng thái tài khoản (Hỗ trợ khóa nếu spam hoặc vi phạm)
  isActive            Boolean   @default(true) @map("is_active")

  // === CÁC MỐI QUAN HỆ RECIPROCAL (Giữ nguyên) ===
  pets                 UserPet[]
  encyclopediaFavorites EncyclopediaFavorite[]
  lostReports          LostReport[]

  @@map("users")
}

// 2. Quản lý Hồ sơ Thú cưng của User (User's Pets)
model UserPet {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  breedId     String?  @map("breed_id") // Cho phép null nếu user không rõ giống
  petType     String   @map("pet_type") // cat hoặc dog
  gender      String   @map("gender")   // male, female, unknown
  ageMonths   Int?     @map("age_months")
  weightKg    Float?   @map("weight_kg")
  description String?  @db.Text
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")

  // Quan hệ: Một pet thuộc về một User. Nếu User bị xóa, xóa luôn hồ sơ Pet (Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lostReports LostReport[]

  @@map("user_pets")
}

// 3. Danh sách Giống loài Yêu thích - Phân hệ Bách Khoa Thư (Encyclopedia Favorites)
model EncyclopediaFavorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  breedId   String   @map("breed_id") // ID chuỗi từ Cat/Dog API bên thứ ba
  petType   String   @default("cat") @map("pet_type")         // Mặc định hoặc tự map dựa vào logic
  createdAt DateTime @default(now()) @map("created_at")

  // Quan hệ
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("encyclopedia_favorites")
}

// 4. Bản tin Báo lạc - Phân hệ Lost & Found Radar (Lost Reports)
model LostReport {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  petId              String?  @map("pet_id") // null nếu điền tay thông tin bên dưới
  
  // Thông tin điền tay khi không chọn pet có sẵn
  petName            String?  @map("pet_name")
  petType            String?  @map("pet_type")
  breedName          String?  @map("breed_name")
  rewardAmount       Decimal  @default(0) @db.Decimal(12, 2) @map("reward_amount") // Chuẩn tiền tệ cần dùng Decimal
  distinctiveFeatures String? @db.Text @map("distinctive_features")
  contactPhone       String   @map("contact_phone")
  
  // Dữ liệu phục vụ tính toán bán kính Radar Định Vị (Giai đoạn 2)
  latitude           Float    @map("latitude") // PostgreSQL dùng Float cho tọa độ rất mượt
  longitude          Float    @map("longitude")
  lostAddress        String   @map("lost_address")
  
  status             String   @default("lost") // lost, found, cancelled
  lostAt             DateTime @map("lost_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Quan hệ
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet                UserPet?          @relation(fields: [petId], references: [id], onDelete: SetNull) // Nếu xóa hồ sơ pet, giữ lại bài đăng báo lạc nhưng set trường này bằng null
  images             LostReportImage[]

  @@map("lost_reports")
}

// 5. Lưu trữ nhiều hình ảnh cho một bài đăng báo lạc (Report Images)
model LostReportImage {
  id        String   @id @default(uuid())
  reportId  String   @map("report_id")
  imageUrl  String   @map("image_url")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  // Quan hệ
  report    LostReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("lost_report_images")
}

// 6. Danh sach Giong loai (Breeds) - Sync tu Cat API & Dog API, co ban dich tieng Viet
model Breed {
  id          String   @id              // Original ID from Cat/Dog API (e.g. "abys", "1")
  petType     String   @map("pet_type") // "cat" | "dog"

  // English fields - pulled directly from external API
  nameEn        String  @map("name_en")
  descriptionEn String? @db.Text @map("description_en")
  temperamentEn String? @map("temperament_en") // e.g. "Active, Curious, Playful"
  originEn      String? @map("origin_en")       // e.g. "Ethiopia"

  // Vietnamese fields - auto-translated by Gemini AI script
  nameVi        String? @map("name_vi")
  descriptionVi String? @db.Text @map("description_vi")
  temperamentVi String? @map("temperament_vi")
  originVi      String? @map("origin_vi")

  // Common fields - no translation needed
  lifeSpan    String? @map("life_span")  // e.g. "12 - 16" (years)
  weightKg    String? @map("weight_kg")  // e.g. "3 - 7" (kg range)
  imageUrl    String? @map("image_url")
  wikipediaUrl String? @map("wikipedia_url")

  // Tracking fields
  isTranslated Boolean  @default(false) @map("is_translated") // true after Gemini script runs
  syncedAt     DateTime @default(now()) @map("synced_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  @@map("breeds")
}